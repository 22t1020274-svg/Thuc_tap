@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var cartLineCount = 0;
    var ctx = HttpContextAccessor.HttpContext;
    if (ctx?.Session != null)
        cartLineCount = ShoppingCartSession.GetCart(ctx.Session).Count;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · SV22T1020274 Shop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/shop-site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SV22T1020274.Shop.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shop-topbar py-2">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">SV22T1020274 Shop</a>
                <button class="navbar-toggler border-secondary shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 mt-2 mt-lg-0 gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 mt-2 mt-lg-0 align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link d-inline-flex align-items-center gap-1" asp-controller="Cart" asp-action="Index">
                                Giỏ hàng
                                @if (cartLineCount > 0)
                                {
                                    <span class="badge bg-warning text-dark">@cartLineCount</span>
                                }
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Order" asp-action="History">Đơn hàng</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Profile">Hồ sơ</a></li>
                            <li class="nav-item d-flex align-items-center">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="shop-topbar-logout">Đăng xuất</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4 flex-grow-1">
        <partial name="_Alerts" />
        @RenderBody()
    </main>

    <footer class="shop-footer py-4 mt-2">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="text-white fw-bold mb-2">SV22T1020274 Shop</div>
                    <p class="small mb-0 opacity-75">Cửa hàng trực tuyến — xem sản phẩm, đặt hàng và theo dõi đơn của bạn.</p>
                </div>
                <div class="col-md-3">
                    <div class="text-white fw-semibold small mb-2">Khám phá</div>
                    <ul class="list-unstyled small mb-0">
                        <li><a asp-controller="Product" asp-action="Index">Danh mục</a></li>
                        <li><a asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <div class="text-white fw-semibold small mb-2">Pháp lý</div>
                    <ul class="list-unstyled small mb-0">
                        <li><a asp-controller="Home" asp-action="Privacy">Quyền riêng tư</a></li>
                    </ul>
                </div>
            </div>
            <hr class="border-secondary opacity-25 my-4" />
            <div class="small opacity-75 text-center text-md-start">&copy; @DateTime.Now.Year SV22T1020274.Shop</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
