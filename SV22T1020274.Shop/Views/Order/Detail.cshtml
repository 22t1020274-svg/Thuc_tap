@model OrderViewInfo
@{
    ViewData["Title"] = $"Đơn #{Model.OrderID}";
    var details = ViewBag.Details as List<OrderDetailViewInfo> ?? new();
    var canCancel = Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a asp-action="History">Đơn hàng</a></li>
        <li class="breadcrumb-item active">#@Model.OrderID</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shop-card mb-4">
            <div class="card-body p-4">
                <h1 class="h4 mb-3">Đơn hàng #@Model.OrderID</h1>
                <p class="mb-1"><span class="text-muted">Trạng thái:</span> <strong>@Model.Status.GetDescription()</strong></p>
                <p class="mb-1 small text-muted">Đặt lúc: @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                @if (Model.AcceptTime.HasValue)
                {
                    <p class="mb-1 small text-muted">Duyệt: @Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                }
                @if (Model.ShippedTime.HasValue)
                {
                    <p class="mb-1 small text-muted">Giao cho vận chuyển: @Model.ShippedTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                }
                @if (Model.FinishedTime.HasValue)
                {
                    <p class="mb-0 small text-muted">Kết thúc: @Model.FinishedTime.Value.ToString("dd/MM/yyyy HH:mm")</p>
                }
            </div>
        </div>

        <div class="card shop-card">
            <div class="card-body p-4">
                <h2 class="h6 mb-3">Sản phẩm</h2>
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Tên</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal sum = 0;
                            }
                            @foreach (var d in details)
                            {
                                var line = d.Quantity * d.SalePrice;
                                sum += line;
                                <tr>
                                    <td>@d.ProductName</td>
                                    <td class="text-end">@d.SalePrice.ToString("N0") đ</td>
                                    <td class="text-center">@d.Quantity</td>
                                    <td class="text-end">@line.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <th colspan="3" class="text-end">Tổng</th>
                                <th class="text-end">@sum.ToString("N0") đ</th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shop-card">
            <div class="card-body p-4">
                <h2 class="h6 mb-2">Giao hàng</h2>
                <p class="small mb-1"><strong>Tỉnh/thành:</strong> @Model.DeliveryProvince</p>
                <p class="small mb-0" style="white-space: pre-wrap;">@Model.DeliveryAddress</p>
                @if (!string.IsNullOrWhiteSpace(Model.ShipperName))
                {
                    <hr />
                    <p class="small mb-0"><strong>Người giao:</strong> @Model.ShipperName — @Model.ShipperPhone</p>
                }
            </div>
        </div>
        @if (canCancel)
        {
            <form asp-action="Cancel" method="post" class="mt-3" onsubmit="return confirm('Bạn có chắc muốn hủy đơn này?');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.OrderID" />
                <button type="submit" class="btn btn-outline-danger w-100">Hủy đơn hàng</button>
            </form>
        }
    </div>
</div>
