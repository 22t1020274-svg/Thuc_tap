@model PagedResult<OrderSearchInfo>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    var statusCode = ViewBag.StatusCode as int? ?? 0;
}

<h1 class="h3 mb-4">Lịch sử đơn hàng</h1>

<div class="card shop-card mb-4">
    <div class="card-body p-3">
        <form method="get" asp-action="History" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small mb-0">Trạng thái</label>
                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                    @if (statusCode == 0)
                    {
                        <option value="0" selected>Tất cả</option>
                    }
                    else
                    {
                        <option value="0">Tất cả</option>
                    }
                    @foreach (var opt in new[] { OrderStatusEnum.New, OrderStatusEnum.Accepted, OrderStatusEnum.Shipping, OrderStatusEnum.Completed, OrderStatusEnum.Cancelled, OrderStatusEnum.Rejected })
                    {
                        if (statusCode == (int)opt)
                        {
                            <option value="@((int)opt)" selected>@opt.GetDescription()</option>
                        }
                        else
                        {
                            <option value="@((int)opt)">@opt.GetDescription()</option>
                        }
                    }
                </select>
            </div>
            <input type="hidden" name="page" value="1" />
        </form>
    </div>
</div>

@if (Model.DataItems.Count == 0)
{
    <p class="text-muted">Chưa có đơn hàng.</p>
}
else
{
    <div class="table-responsive card shop-card">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Mã đơn</th>
                    <th>Thời điểm</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.DataItems)
                {
                    <tr>
                        <td>#@o.OrderID</td>
                        <td>@o.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">@o.SumOfPrice.ToString("N0") đ</td>
                        <td><span class="badge bg-secondary">@o.Status.GetDescription()</span></td>
                        <td><a asp-action="Detail" asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-primary">Chi tiết</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @foreach (var pi in Model.GetDisplayPages(3))
                {
                    if (pi.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">…</span></li>
                    }
                    else
                    {
                        <li class="page-item @(pi.IsCurrent ? "active" : "")">
                            <a class="page-link" asp-action="History" asp-route-page="@pi.Page" asp-route-status="@statusCode">@pi.Page</a>
                        </li>
                    }
                }
            </ul>
        </nav>
    }
}
